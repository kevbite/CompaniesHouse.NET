                ]
            }],
            "responses": {
                "200": {
                    "description": "Registered office address resource updated",
                    "schema": {
                        "$ref": "../models/registeredOfficeAddress.json#/definitions/registeredOfficeAddressChange"
                    }
                },
                "401": {
                    "description": "Not authorised to update this transaction"
                },
